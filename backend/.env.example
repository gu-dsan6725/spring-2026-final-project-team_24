# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=knowledge

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=knowledge

# --- Pinecone ---
# Create a dense index whose dimension matches the embedding model (default:
# text-embedding-3-small → 1536). See app/ai/providers/openai_embeddings.py.
PINECONE_API_KEY=
PINECONE_INDEX=knowledge

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=uploads

# --- AI Providers (cloud) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# --- AI Providers (free / open-source model access) ---
# Groq — FREE, no credit card. Get key at https://console.groq.com/
# Used for Stage 2 similarity verification and cost-free pipelines.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Which provider to use for Stage 2 similarity verification:
# "groq" (default, free), "openai", "anthropic", "mistral", "ollama"
VERIFICATION_PROVIDER=groq

# Item generation pipeline — must match a provider with a non-empty API key (see app/config.py)
ITEM_GENERATION_PROVIDER=groq

# --- MinerU (local PDF/document extraction) ---
# pip install mineru  (already in requirements.txt)
# Backend: "pipeline" (default, CPU), "vlm-auto-engine" (GPU, uses VLM),
#          "vlm-huggingface", "vlm-vllm-engine", "hybrid-auto-engine"
# NOTE: "auto" is NOT valid — MinerU's do_parse silently no-ops on it.
MINERU_BACKEND=pipeline
EXTRACTED_DIR=data/extracted

# --- Paper ingestion (section split + sub-chunk + embed) ---
# Optional: when set, ingest-paper mirrors the finished paper folder into this
# directory (e.g. an Obsidian vault path) after section/chunk/embed are done.
PAPER_EXPORT_DIR=
DOC_CHUNK_SIZE=1500
DOC_CHUNK_OVERLAP=200

# --- Auth ---
JWT_SECRET=changeme-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Observability (optional) ---
# PROMETHEUS_METRICS_ENABLED=true
# PROMETHEUS_METRICS_PATH=/metrics
